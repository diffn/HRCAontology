@prefix : <http://www.semanticweb.org/ays/ontologies/2025/10/untitled-ontology-42/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/ays/ontologies/2025/10/untitled-ontology-42/> .

<http://www.hrca.org/ontology/HRCAontology> rdf:type owl:Ontology ;
                                             owl:versionIRI <http://www.hrca.org/ontology/HRCAontology/3.0> .

#################################################################
#    Annotation properties
#################################################################

###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


###  http://www.semanticweb.org/ays/ontologies/2025/10/untitled-ontology-42/priority_indicator
:priority_indicator rdf:type owl:AnnotationProperty ;
                    rdfs:comment "用于描述优先级相关指标的分组标签，不参与推理" .


###  http://www.semanticweb.org/ays/ontologies/2025/10/untitled-ontology-42/priority_indicator_variable
:priority_indicator_variable rdf:type owl:AnnotationProperty ;
                             rdfs:comment "用于描述优先级相关变量的分组标签，不参与推理" .


###  http://www.semanticweb.org/ays/ontologies/2025/10/untitled-ontology-42/priority_indicator_weight
:priority_indicator_weight rdf:type owl:AnnotationProperty ;
                           rdfs:comment "用于描述优先级相关变量权重的分组标签，不参与推理" .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/ays/ontologies/2025/10/untitled-ontology-42/allocatedTo
:allocatedTo rdf:type owl:ObjectProperty ;
             rdfs:domain :AssemblyExecution ,
                         :AssemblyTask ,
                         :HRCAProcess ;
             rdfs:range :Agent ,
                        :Component ,
                        :HRCASystem .


###  http://www.semanticweb.org/ays/ontologies/2025/10/untitled-ontology-42/assembledInto
:assembledInto rdf:type owl:ObjectProperty ;
               rdfs:domain :AssemblyTask ;
               rdfs:range :Assembly ,
                          :Part .


###  http://www.semanticweb.org/ays/ontologies/2025/10/untitled-ontology-42/assemblyOfProduct
:assemblyOfProduct rdf:type owl:ObjectProperty ;
                   rdfs:domain :Assembly ,
                               :ProductData ;
                   rdfs:range :Product ,
                              :ProductData .


###  http://www.semanticweb.org/ays/ontologies/2025/10/untitled-ontology-42/candidateAgent
:candidateAgent rdf:type owl:ObjectProperty ;
                rdfs:domain :AssemblyExecution ,
                            :AssemblyTask ,
                            :HRCAProcess ;
                rdfs:range :Agent ,
                           :Component ,
                           :HRCASystem .


###  http://www.semanticweb.org/ays/ontologies/2025/10/untitled-ontology-42/capabilityOfType
:capabilityOfType rdf:type owl:ObjectProperty ;
                  rdfs:domain :AssemblyPreparation ,
                              :Capability ,
                              :HRCAProcess ,
                              :TaskAllocation ;
                  rdfs:range :AssemblyPreparation ,
                             :CapabilityType ,
                             :HRCAProcess ,
                             :TaskAllocation .


###  http://www.semanticweb.org/ays/ontologies/2025/10/untitled-ontology-42/containsComponent
:containsComponent rdf:type owl:ObjectProperty ;
